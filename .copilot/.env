COPILOT_DISABLE_AUTO_UPDATE=true

GH_TOKEN=
GH_COPILOT_TOKEN=
GITHUB_COPILOT_TOKEN=

# https://context7.com/docs/howto/api-keys
CONTEXT7_API_KEY=

# https://docs.ref.tools/context/install
REF_API_KEY=

POSTGRES_HOST=
POSTGRES_PORT="5432"
POSTGRES_DATABASE="testdb"
POSTGRES_USER="testuser"
POSTGRES_PASSWORD="testpassword"

# https://go2docs.graylog.org/current/setting_up_graylog/model_context_protocol__mcp__tools.htm
GRAYLOG_TST_TOKEN="Basic $(echo -n 'username:token' | base64 -w 0)"
GRAYLOG_PRD_TOKEN="Basic $(echo -n 'username:token' | base64 -w 0)"

# https://support.atlassian.com/atlassian-rovo-mcp-server/docs/configuring-authentication-via-api-token/
JIRA_TOKEN="Basic $(echo -n 'username:token' | base64 -w 0)"
